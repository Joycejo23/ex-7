// Import the http module
const http = require("http");

// Configuration
const name = "Your Name"; // Added this to prevent a ReferenceError
const PORT = 3000;

// Create a server
const server = http.createServer((req, res) => {
    const currentTime = new Date();

    // Default Success Header
    res.writeHead(200, { "Content-Type": "text/html" });

    // Routing Logic
    if (req.url === "/") {
        res.write(`<h2>Hello from ${name}'s Node.js Server</h2>`);
        res.write(`<p>Current Date and Time: ${currentTime}</p>`);
    } 
    else if (req.url === "/about") {
        res.write("<h2>About Page</h2>");
        res.write("<p>This server is created using Node.js</p>");
    } 
    else if (req.url === "/contact") {
        res.write("<h2>Contact Page</h2>");
        res.write("<p>Feel free to reach out via cosmic signals.</p>");
    } 
    else {
        // Handle 404 - Page Not Found
        res.writeHead(404, { "Content-Type": "text/html" });
        res.write("<h2>404 - Page Not Found</h2>");
    }

    // End the response
    res.end();
});

// Start the server
server.listen(PORT, "0.0.0.0", () => {
    console.log(`Server running at http://localhost:${PORT}`);
    console.log("Press Ctrl+C to stop the server");
});
